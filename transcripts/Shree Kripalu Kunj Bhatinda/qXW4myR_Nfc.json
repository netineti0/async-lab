8\u092c \u0915\u0941\u091b \u0938\u092e\u093e \u091c\u093e\u090f, \u0905\u0928\u0902\u0924 \u092e\u093e\u0924\u094d\u0930\u093e \u0915\u093e \u092c\u0921\u093c\u093e, \u0935\u094b \u0939\u0948 \u092c\u094d\u0930\u0939\u094d\u092e, unlimited power \u0935\u093e\u0932\u093e, \u0909\u0938\u0915\u094b \u0915\u0939\u0924\u0947 \u0939\u0948\u0902 \u092c\u094d\u0930\u0939\u094d\u092e\u0964 \u0906\u0917\u0947 \u0915\u0939\u093e \u0935\u0947\u0926 \u0928\u0947 \u092f\u0924\u094b\u0935\u093e \u0907\u092e\u093e\u0928\u093f \u092d\u0942\u0924\u093e\u0928\u093f \u091a\u093e\u092f\u0928\u094d\u0924\u0947 \u092f\u0947\u0928 \u091a\u093e\u0924\u093e\u0928\u093f \u091c\u0940\u0935\u0928\u094d\u0924\u093f \u092f\u0924\u094d\u092a\u094d\u0930\u093f\u092f\u0902\u0924\u094d\u092f \u0935\u093f\u0938\u092e\u094d\u0935\u093f\u0936\u0928\u094d\u0924\u093f \u0924\u0924\u094d\u0935\u093f\u091c\u093f\u091c\u094d\u091e\u093e\u0938\u0938\u094d\u0935 \u0924\u0924\u094d\u0935\u0939\u092e\u0947\u0924\u093f \u0924\u0924\u094d\u0930\u093f\u092f\u094b\u092a\u0928\u093f\u0936\u0924\u094d \u091c\u093f\u0938\u0938\u0947 \u0938\u0902\u0938\u093e\u0930 \u0909\u0924\u094d\u092a\u0928 \u0939\u094b\u0924\u093e \u0939\u094b \u091c\u093f\u0938\u0938\u0947 \u0938\u0902\u0938\u093e\u0930 \u0915\u093e \u092a\u093e\u0932\u0928, \u092a\u094b\u0936\u0928, \u0930\u0915\u094d \u0914\u0930 \u091c\u093f\u0938\u092e\u0947\u0902 \u0938\u0902\u0938\u093e\u0930 \u0915\u093e \u0932\u092f \u0939\u094b \u091c\u093e\u090f, \u0935\u094b \u0939\u0948 \u092c\u094d\u0930\u0939\u094d\u092e\u0964 \u092f\u093e\u0928\u0940 \u091c\u094b \u0938\u092c\u0938\u0947 \u092c\u0921\u093c\u093e \u0939\u094b, \u0928 \u0924\u0924\u094d\u0938\u092e\u0936\u094d\u091a\u093e\u092d\u094d\u092f\u0926\u093f\u0915\u0937\u094d\u091f\u0926\u0943\u0936\u094d\u092f\u0924\u0947\u0964 \u0935\u0947\u0926 \u092e\u0902\u0924\u094d\u0930 \u0915\u0939\u0924\u093e \u0939\u0948, \u091c\u093f\u0938\u0915\u0947 \u0915\u094b\u0908 \u092c\u0930\u093e\u092c\u0930 \u092d\u094