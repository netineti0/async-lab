u0932\u0921\u093c\u093e\u0915\u093e \u0905\u0917\u0932\u0947 \u0938\u094d\u091f\u093e\u0930 \u0915\u0940 \u092d\u093e\u0908 \u0939\u0947\u0932\u094b \u092e\u093f\u0932\u093e \u092d\u0948\u092f\u093e \u090f\u0915 \u0905\u091f\u0915 \u0917\u092f\u093e\u0964 \u0906\u091c\u0940 \u0939\u0948! \u0915\u0940\u091c\u0947! \u0915\u0940\u091c\u0947! \u0939\u092e\u093e\u0930\u093e \u092e\u093e\u0930\u094d\u0917 \u0939\u0948\u0964 \u0936\u094d\u0930\u0940 \u0913\u092e \u0936\u0902\u0915\u0930 \u0936\u0941\u0915\u094d\u0932 \u0932\u0916\u0928\u090a, \u0936\u094d\u0930\u0940 \u0930\u093e\u0927\u0947\u0936\u094d\u092f\u093e\u092e \u0936\u0941\u0915\u094d\u0932 \u091a\u0941\u0932\u094d\u0939\u094b\u0938, \u0936\u094d\u0930\u0940 \u0930\u093e\u0927\u0947\u0936\u094d\u092f\u093e\u092e \u0936\u0941\u0915\u094d\u0932 \u091a\u0941\u0932\u094d\u0939\u094b\u0938\u0964 \u0924\u094d\u0930\u093f\u0932\u094b\u0927 \u0915\u0941\u092e\u093e\u0930 \u0936\u0941\u0915\u094d\u0930 \u0916\u091c\u0930\u0940, \u0924\u094d\u0930\u093f\u0917\u0902\u0917\u093e \u092a\u094d\u0930\u0938\u093e\u0926 \u0936\u0941\u0915\u094d\u0930 \u091c\u0928\u094d\u092e\u093e \u092e\u093e\u090a, \u0924\u094d\u0930\u093f\u0917\u0902\u0917\u093e \u092a\u094d\u0930\u0938\u093e\u0926 \u0936\u0941\u0915\u094d\u0930 \u091c\u0928\u094d\u092e\u093e \u092e\u093e\u090a, \u0924\u094d\u0930\u093f\u0917\u0902\u0917\u093e \u092a\u094d\u0930\u0938\u093e\u0926 \u0936\u0941\u0915\u094d\u0930, \u0924\u094d\u0930\u093f\u092f\u0936\u094b\u0915 \u0915\u0941\u092e\u093e\u0930 \u0936\u0941\u0915\u094d\u0930 \u0917\u0902\u0917\u093e \u0915\u093e \u092a\u0942\u0930\u094d\u0935\u093e, \u0924\u094d\u0930\u093f\u092f\u0936\u094b\u0915 \u0915\u0941\u092e\u093e\u0930 \u0936\u0941\u0915\u094d\u0930, \u0924\u094d\u0930\u093f\u092f\u0936\u094b\u0915 \u0915\u0941\u092e\u093e\u0930 \u0936\u0941\u0915\u094d\u0930 \u0938\u093f\u0926\u094d\u0927\u0947\u0936\u094d\u0935\u0930 \u092a\u093f\u0930\u093e\u091c \u0924\u093f\u0935\u093e\u0930\u0940 \u0907\u0932\u093e\u0939\u093e\u092c\u093e\u0926, \u0938\u093f\u0926\u094d\u0927\u0926\u0947\u0935\u0940 \u092a\u094d\u0930\u0938\u093e\u0926 \u0924\u093f\u0935\u093e\u0930\u0940 \u092e\u0939\u0947\u0936\u0917\u0902\u091c, \u0938\u093f\u0930\u093e\u091c\u0928\u093e\u0930\u093e\u092f\u0923 \u0924\u093f\u0935\u093e\u0930\u0940 \u092d\u0924\u094d\u0924\u093f\u092f\u094b\u0902, \u0938\u093f\u0930\u0930\u092e\u0947\u0936\u094d\u0935\u0930 \u092a\u094d\u0930\u0938\u093e\u0926 \u0924\u093f\u0935\u093e\u0930\u0940 \u092d\u0924\u094d\u0924\u093f\u092f\u094b\u0902, \u0938\u093f\u0930\u0930\u092e\u0947\u0936\u094d\u0935\u0930 \u092a\u094d\u0930\u0938\u093e\u0926 \u0924\u093f\u0935\u093e\u0930\u0940 \u092d\u0924\u094d\u0924\u093f\u092f\u094b\u0902 \u0924\u0947\u0930\u0940 \u0938\u0926\u093e\u0936\u093f\u0935 \u0936\u0941\u092d \u0916\u0928\u0935\u093e\u0930\u0940, \u0924\u0947\u0930\u0940 \u0917\u092f\u093e \u092a\u094d\u0930\u0936\u093e\u0938\u0928 \u0936\u0941\u092d \u0916\u0928\u0935\u093e\u0930\u0940, \u0924\u0947\u0930\u0940 \u0905\u0928\u094b\u092a\u0926\u093f\u0928 \u0936\u0941\u092d \u0916\u0928\u0935\u093e\u0930\u0940, \u0924\u0947\u0930\u0940 \u0938\u0926\u093e\u0936\u093f\u0935 \u0936\u0941\u092d \u0916\u0928\u0935\u093e\u0930\u0940, \u0924\u0947\u0930\u0940 \u0917\u092f\u093e \u092a\u094d\u0930\u0936\u093e\u0938\u0928 \u0936\u0941\u092d \u0916\u0928\u0935\u093e\u0930\u0940, \u0905\u091a\u094d\u091b\u093e \u0938\u0926\u093e \u0939\u093e\u0901 \u0909\u092e\u093e\u0936\u0902\u0915\u0930 \u0915\u0940 \u092a\u093e\u0930\u094d\u091f\u0940 \u0926\u093f\u0928\u0935\u093e\u0938 \u0936\u094d\u0930\u0940\u092e\u093e\u0924\u093e \u092a\u094d\u0930\u0938\u093e\u0926 \u0936\u0941\u0915\u094d\u0932\u093e \u0932\u0916\u0928\u090a \u0936\u094d\u0930\u0940\u092e\u093e\u0924\u093e \u092a\u094d\u0930\u0938\u093e\u0926 \u0936\u0941\u0915\u094d\u0932\u093e \u0932\u0916\u0928\u090a \u0936\u094d\u0930\u0940 \u0938\u0902\u092c\u0941\u0928\u093e\u0936\u0941\u0915\u094d\u0932\u093e \u092a\u094d\u0930\u093f\u092f \u0938\u0902\u092c\u0941\u0928\u093e\u0930 \u0936\u0941\u0915\u094d\u0932 \u0932\u0941\u0902\u0921\u093e \u0915\u093e \u092a\u0942\u0930\u094d\u0935\u093e, \u0938\u0902\u092c\u0941\u0928\u093e\u0930 \u0936\u0941\u0915\u094d\u0932 \u0932\u0941\u0902\u0921\u093e \u0915\u093e \u092a\u0942\u0930\u094d\u0935\u093e, \u092a\u094d\u0930\u093f\u092f \u0930\u093e\u092e\u0926\u093e\u0930\u093e\u0930 \u0936\u0941\u0915\u094d\u0932 \u091c\u094c\u0928\u092a\u0941\u0930, \u092a\u094d\u0930\u093f\u092f \u0936\u094d\u0930\u0940\u092e\u094b\u0930\u094d\u0924\u0947\u0936\u094d\u0935\u0930 \u0915\u0940 \u0932\u0916\u0928\u090a, \u092a\u094d\u0930\u093f\u092f \u0939\u0930\u094d\u0937\u0947\u0902\u0926\u094d\u0930 \u0924\u093f\u0935\u093e\u0930\u0940 \u0916\u0928\u0935\u093e\u0930\u0940 \u0938\u093f\u0939\u0930 \u0936\u0902\u0915\u0930 \u0924\u093f\u0935\u093e\u0930\u0940 \u0916\u0928\u0935\u093e\u0930\u0940 \u0905\u091a\u094d\u091b\u093e \u0936\u0902\u0915\u0930 \u092c\u094b\u0932 \u0928\u0939\u0940\u0902 \u0930\u0939\u0947 \u0939\u0948\u0902 \u0924\u094d\u0930\u093f\u092d\u094b\u0932\u093e \u0928\u093e\u0930\u093e\u092f\u0923 \u0909\u092a\u0930\u0938\u0926\u0947\u092a\u0941\u0930 \u0914\u0930 \u0915\u0939\u093e\u0901 \u0915\u0947 \u0906\u0930\u094d\u092f\u0935\u0930\u094d\u0924 \u0908\u0936\u094d\u0935\u0930 \u091a\u0932\u0924\u0940 \u0916\u0928\u0935\u093e\u0930\u0940 \u092e\u0947\u0902 \u0908\u0936\u094d\u0935\u0930 \u091a\u0932\u0924\u0940 \u0935\u093e\u0930\u0940 \u0916\u0928\u0935\u093e\u0930\u0940 \u0939\u094b \u0917\u092f\u093e \u0932\u0947 \u0917\u0908\u0964 \u092c\u0939\u0941\u0924 \u0905\u091a\u094d\u091b\u093e \u0939\u0948\u0964 \u0917\u093e\u0921\u093c\u0940 \u0915\u092d\u0940 \u0939\u092e \u092e\u0947\u0902 \u0939\u0940 \u0930\u0939\u094b \u0917\u093e\u0921\u093c\u0940 \u0915\u092d\u0940 \u0926\u0947\u0916\u093e \u092a\u093f\u0936, \u091a\u0932\u094b \u091a\u0932\u094b \u091a\u0932\u094b\u0964 \u0926\u0947\u0916\u093e \u092f\u093e\u0930 \u0907\u0927\u0930 \u0906\u0913, \