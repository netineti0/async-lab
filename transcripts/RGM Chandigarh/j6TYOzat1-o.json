e\u093e\u0930\u0947 \u0928\u093e\u092e \u0939\u0948\u0902 \u0909\u0928\u0915\u094b\u0964 \u0914\u0930 \u0926\u0941\u0928\u093f\u092f\u093e \u0938\u092c \u0915\u094d\u092f\u093e \u0915\u0930\u0947\u0917\u0940 \u092f\u0947 \u0930\u093e\u0915\u094d\u0937\u0938 \u0915\u094b \u092a\u094d\u0930\u0923\u093e\u092e \u0915\u0930 \u0930\u0939\u0947 \u0939\u0948\u0902? \u0924\u094b \u092a\u094d\u0930\u0923\u093e\u092e \u0915\u0930\u0928\u093e \u092c\u0941\u0930\u093e \u0928\u0939\u0940\u0902\u0964 \u0906\u092a \u0915\u0939\u0947\u0902\u0917\u0947 \u0926\u0947\u0935\u0940\u091c\u0940 \u0915\u093e \u092e\u0902\u0926\u093f\u0930 \u092a\u0921\u093c\u0924\u093e \u0939\u0948 \u0935\u0939\u093e\u0901 \u0939\u092e \u0939\u093e\u0925 \u091c\u094b\u0921\u093c\u0924\u0947 \u0939\u0948\u0902, \u0926 \u0935\u094b \u0926\u0947\u0935\u0940\u091c\u0940 \u0915\u0947 \u0905\u0902\u0926\u0930 \u091c\u094b \u092c\u0948\u0920\u0947 \u0939\u0941\u090f \u092e\u0939\u093e\u0926\u0947\u0935\u093e\u091c\u0940 \u0939\u0948\u0902, \u0909\u0928\u0915\u093e \u0915\u093f\u0938\u0915\u094b \u092a\u094d\u0930\u0923\u093e\u092e \u0915\u0930\u0942\u0901? \u0905\u092a\u0928\u0947 \u092a\u094d\u0930\u093f\u092f \u0915\u093f\u0938\u0915\u094b \u092a\u094d\u0930\u0923\u093e\u092e \u0915\u0930\u0942\u0901? \u0938\u0930\u094d\u0935\u0924\u094d\u0930 \u0909\u0928\u0915\u093e \u0939\u0940 \u0905\u0928\u0941\u092d\u0935 \u0915\u0930\u0942\u0901\u0964 \u0910\u0938\u0940 \u0905\u0928\u0902\u0924\u0924\u093e \u0915\u0947 \u0926\u094d\u0935\u093e\u0930\u093e \u0939\u0940 \u091c\u094b \u0939\u092e\u093e\u0930\u0940 \u090f\u0915 \u092c\u0921\u093c\u0940 \u092d\u093e\u0930\u0940 \u0915\u092e\u0940 \u0939\u0948, \u0935\u0940\u0915\u0928\u0947\u0938 \u0939\u0948, \u092f\u0947 \u0905\u0917\u0930 \u0939\u092e\u093e\u0930\u0940 \u090f\u0915 \u0926\u0942\u0930 \u0939\u094b \u091c\u093e\u090f\u0917\u0940, \u0924\u094b \u092b\u093f\u0930 \u0905\u0939\u0902\u0915\u093e\u0930, \u0915\u0930\u094d\u092e\u092a\u093e\u092a, \u092d\u094d\u093