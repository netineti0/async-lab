f \u0939\u094b, \u092c\u091a\u094d\u091a\u093e \u0939\u094b, \u091c\u0935\u093e\u0928 \u0939\u094b, \u091a\u093e\u0939\u0947 \u092c\u0942\u095d\u093e \u0939\u094b, \u091c\u092c \u0909\u0938\u092e\u0947\u0902 \u0938\u0902\u0938\u093e\u0930 \u0938\u0947 \u092c\u0948\u0930\u093e\u0917\u094d\u092f \u0939\u094b\u0917\u093e\u0964 \u0924\u092c \u0915\u094b\u0908 \u0938\u0902\u0924 \u0905\u092a\u0928\u093e \u0915\u092e\u093e\u0932 \u0926\u093f\u0916\u093e \u0938\u0915\u0924\u093e \u0939\u0948\u0964 \u0935\u0930\u0928\u093e \u092c\u0921\u093c\u0947-\u092c\u0921\u093c\u0947 \u0938\u0902\u0924 \u0906\u090f \u0939\u093e\u0930 \u0917\u090f, \u092d\u0917\u0935\u093e\u0928 \u0906\u090f \u0935\u094b \u092d\u0940 \u0939\u093e\u0930 \u0917\u090f\u0964 \u0939\u092e\u0932\u094b\u0917 \u0915\u094d\u092f\u094b\u0902 \u092c\u0948\u0920\u0947 \u0939\u0948\u0902? \u0905\u0930\u0947 \u0915\u094d\u092f\u093e \u0939\u092e\u0932\u094b\u0917\u094b\u0902 \u0915\u094b \u0915\u094b\u0908 \u0938\u0902\u0924 \u0928\u0939\u0940\u0902 \u092e\u093f\u0932\u093e \u0905\u0928\u093e\u0927\u093f\u0915\u093e\u0932 \u0938\u0947 \u0905\u092c \u0924\u0915? \u0938\u093e\u0930\u0947 \u092d\u0917\u0935\u093e\u0928 \u0915\u0947 \u0905\u0935\u0924\u093e\u0930\u094b\u0902 \u0915\u094b \u092d\u0940 \u0926\u0947\u0916\u093e \u0939\u0948, \u0930\u093e\u092e \u0915\u0943\u0937\u094d\u0923 \u0915\u094b \u092d\u0940 \u0926\u0947\u0916\u093e \u0939\u0948 \u0939\u092e\u0932\u094b\u0917\u094b\u0902 \u0928\u0947\u0964 \u0938\u0902\u0924\u094b\u0902 \u0915\u0940 \u0915\u094c\u0928 \u0915\u0939\u0947? \u090f\u0915 \u0926\u094b \u092c\u093e\u0930 \u0928\u0939\u0940\u0902, \u0939\u0930 \u0905\u0935\u0924\u093e\u0930 \u0928\u0947 \u0926\u0947\u0916\u093e \u0939\u0948, \u0932\u0947\u0915\u093f\u0928 \u091c\u093e\u0915\u0940 \u0930\u0939\u0940 \u092d\u093e\u0935\u0928\u093e \u091c\u0948\u0938\u0940, \u0935\u0939\u0940 \u0915\u0947 \u0935\u0939\u0940 \u0915\u0921\u093c\u0947 \u0930\u0939\u0947\u0902, \u0938\u0902\u0924\u094b\u0902 \u09